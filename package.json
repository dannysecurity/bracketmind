{
  "name": "bracketmind",
  "version": "0.1.0",
  "description": "Tournament bracket simulator with team ratings, game simulation, and CLI",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "bracketmind": "dist/index.js"
  },
  "scripts": {
    "build": "tsc && mkdir -p dist/web && cp src/web/style.css dist/web/",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": ["tournament", "bracket", "simulator", "elo"],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.10.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
